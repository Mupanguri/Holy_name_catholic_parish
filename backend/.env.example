# Copy this to .env on EC2 and fill in real values — never commit .env to git
NODE_ENV=production
PORT=5000

# PostgreSQL on same EC2 instance
DATABASE_URL=postgresql://holyname:YOUR_DB_PASSWORD@localhost:5432/holy_name_parish
DB_NAME=holy_name_parish

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Your production domain (used for CORS)
FRONTEND_URL=https://yourdomain.com
FRONTEND_WWW_URL=https://www.yourdomain.com
